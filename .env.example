# ModelSquare Environment Configuration
# Copy this file to .env and modify as needed

# ===========================================
# Application Settings
# ===========================================
APP_NAME=ModelSquare
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# Database Settings (PostgreSQL)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=modelsquare
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/modelsquare

# ===========================================
# Redis Settings
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# MinIO Object Storage
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_TEMP=temp

# ===========================================
# Triton Inference Server
# ===========================================
TRITON_URL=localhost:8001
TRITON_MODEL_REPOSITORY=/models

# ===========================================
# SRS 6.0 Streaming Server
# ===========================================
SRS_RTMP_PUBLIC_URL=rtmp://localhost:10005
SRS_HLS_PUBLIC_URL=http://localhost:10007

# ===========================================
# JWT Authentication
# ===========================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=100

# ===========================================
# Frontend Settings (Vite)
# ===========================================
VITE_API_URL=http://localhost:8000
