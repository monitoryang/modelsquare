# ModelSquare 公网生产环境配置
# 适用场景：通过公网 IP 对外提供服务
# 使用方式：cp .env.production .env && docker compose build web && docker compose up -d
# 注意：部署前务必修改 SECRET_KEY 为强随机字符串

# ===========================================
# Application Settings
# ===========================================
APP_NAME=ModelSquare
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY

# ===========================================
# Database Settings (PostgreSQL)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=modelsquare
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5442/modelsquare

# ===========================================
# Redis Settings
# ===========================================
REDIS_URL=redis://localhost:6389/0

# ===========================================
# MinIO Object Storage
# 公网访问使用公网 IP:9010，容器内部仍走 minio:9000
# ===========================================
MINIO_ENDPOINT=182.150.116.35:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_TEMP=temp

# ===========================================
# Triton Inference Server
# ===========================================
TRITON_URL=localhost:8021
TRITON_MODEL_REPOSITORY=/models

# ===========================================
# vLLM Multimodal LLM Server
# ===========================================
VLLM_URL=http://localhost:8110
VLLM_MODEL_NAME=qwen3-vl

# ===========================================
# SRS Streaming Server
# ===========================================
SRS_RTMP_URL=rtmp://localhost:1945/live
SRS_HTTP_URL=http://localhost:8090
SRS_RTMP_PUBLIC_URL=rtmp://182.150.116.35:1945/live
SRS_HTTP_PUBLIC_URL=http://182.150.116.35:8090

# ===========================================
# JWT Authentication
# ===========================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# CORS Settings（允许公网前端域名跨域）
# ===========================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3010","http://182.150.116.35:3010"]

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=100

# ===========================================
# Frontend Settings (Vite 构建时注入，指向公网后端)
# ===========================================
VITE_API_URL=http://182.150.116.35:8020
VITE_SRS_HTTP_URL=http://182.150.116.35:8090
