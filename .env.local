# ModelSquare 本地开发/测试环境配置
# 适用场景：本机开发调试，前后端均通过 172.16.20.33 访问
# 使用方式：cp .env.local .env && docker compose build web && docker compose up -d

# ===========================================
# Application Settings
# ===========================================
APP_NAME=ModelSquare
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=local-dev-secret-key-not-for-production

# ===========================================
# Database Settings (PostgreSQL)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=modelsquare
DATABASE_URL=postgresql+asyncpg://postgres:postgres@172.16.20.33:10001/modelsquare

# ===========================================
# Redis Settings
# ===========================================
REDIS_URL=redis://172.16.20.33:10002/0

# ===========================================
# MinIO Object Storage
# ===========================================
MINIO_ENDPOINT=172.16.20.33:10003
MINIO_PUBLIC_ENDPOINT=172.16.20.33:10003
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_TEMP=temp

# ===========================================
# Triton Inference Server
# ===========================================
TRITON_URL=172.16.20.33:10020
TRITON_MODEL_REPOSITORY=/models

# ===========================================
# vLLM Multimodal LLM Server
# ===========================================
VLLM_URL=http://172.16.20.33:10030
VLLM_MODEL_NAME=qwen3-vl

# ===========================================
# SRS Streaming Server
# ===========================================
SRS_RTMP_URL=rtmp://172.16.20.33:10005/live
SRS_HTTP_URL=http://172.16.20.33:10007
SRS_RTMP_PUBLIC_URL=rtmp://172.16.20.33:10005/live
SRS_HTTP_PUBLIC_URL=http://172.16.20.33:10007

# ===========================================
# JWT Authentication
# ===========================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGINS=["http://172.16.20.33:10040","http://172.16.20.33:10011"]

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=100

# ===========================================
# Frontend Settings (Vite 构建时注入)
# ===========================================
VITE_API_URL=http://172.16.20.33:10010
VITE_SRS_HTTP_URL=http://172.16.20.33:10007
