# ModelSquare 本地开发/测试环境配置
# 适用场景：本机开发调试，前后端均通过 localhost 访问
# 使用方式：cp .env.local .env && docker compose build web && docker compose up -d

# ===========================================
# Application Settings
# ===========================================
APP_NAME=ModelSquare
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=local-dev-secret-key-not-for-production

# ===========================================
# Database Settings (PostgreSQL)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=modelsquare
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5442/modelsquare

# ===========================================
# Redis Settings
# ===========================================
REDIS_URL=redis://localhost:6389/0

# ===========================================
# MinIO Object Storage
# ===========================================
MINIO_ENDPOINT=localhost:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_TEMP=temp

# ===========================================
# Triton Inference Server
# ===========================================
TRITON_URL=localhost:8021
TRITON_MODEL_REPOSITORY=/models

# ===========================================
# vLLM Multimodal LLM Server
# ===========================================
VLLM_URL=http://localhost:8110
VLLM_MODEL_NAME=qwen3-vl

# ===========================================
# SRS Streaming Server
# ===========================================
SRS_RTMP_URL=rtmp://localhost:1945/live
SRS_HTTP_URL=http://localhost:8090
SRS_RTMP_PUBLIC_URL=rtmp://localhost:1945/live
SRS_HTTP_PUBLIC_URL=http://localhost:8090

# ===========================================
# JWT Authentication
# ===========================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3010"]

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=100

# ===========================================
# Frontend Settings (Vite 构建时注入)
# ===========================================
VITE_API_URL=http://localhost:8020
VITE_SRS_HTTP_URL=http://localhost:8090
